# WordPress REST API base URL (no trailing slash)
# Example: https://cms.yourclient.com
WP_API_URL=

# Secret token — must match the value set in the WP plugin's
# "Revalidation Token" field (wp-plugin/fenceco-cpt.php).
# Next.js will reject any revalidation webhook that doesn't include this.
WP_REVALIDATE_TOKEN=change-me-to-a-long-random-string
